# Local dev secrets for Smart Cart. Copy to .dev.vars (gitignored).
# Production values are wrangler secrets, never committed.

# D1 is a wrangler binding (no connection string needed locally).

# Better Auth: generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<openssl rand -base64 32>"
BETTER_AUTH_URL="http://localhost:3000"

# Resend transactional email (sign-in OTP code). Send from a verified domain.
RESEND_API_KEY="<resend api key>"

# LLM provider key for the meal-planning agent (at least one).
ANTHROPIC_API_KEY="<anthropic api key>"
