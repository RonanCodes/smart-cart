# Local dev secrets for Souso. Copy to .dev.vars (gitignored).
# Production values are wrangler secrets, never committed.
#
# EVERYTHING HERE IS OPTIONAL. `npm run init && npm run start` boots with zero
# keys: sign-in uses the demo skip-login button, meal planning is set-maths, and
# AI/Vectorize features fall back. Fill these in only for the full experience.

# D1 is a wrangler binding (no connection string needed locally).

# Better Auth: generate with: openssl rand -base64 32 (npm run init auto-fills this).
BETTER_AUTH_SECRET="<openssl rand -base64 32>"
BETTER_AUTH_URL="http://localhost:3000"

# Resend transactional email (sign-in OTP code). Send from a verified domain.
# Without it, use the "skip email login" demo button on the sign-in page.
RESEND_API_KEY="<resend api key>"

# LLM provider for AI replan/chat. OpenAI is the primary provider; Anthropic is
# the switchable alternate. At least one enables the AI features (otherwise the
# planner uses set-maths). You only need ONE.
OPENAI_API_KEY="<openai api key>"
ANTHROPIC_API_KEY="<anthropic api key>"

# Braintrust tracing (optional). Sends Vercel AI SDK call logs to Braintrust when
# an LLM key above is set. Project name is configured in src/lib/braintrust-ai.ts.
# Without these, the app runs normally; traces just aren't exported.
BRAINTRUST_API_KEY="<braintrust api key>"
# EU orgs (default is US): https://api-eu.braintrust.dev
BRAINTRUST_API_URL="https://api-eu.braintrust.dev"

# Gated access: comma-separated emails allowed to complete sign-in. The admin
# (tech@discopenguin.com) is always approved. Everyone else is waitlisted. Add
# your own email here to sign in for real, or just use the demo skip-login.
APPROVED_EMAILS="friend@example.com, tester@example.com"

# Comma-separated admin emails (can see /admin). tech@discopenguin.com is always
# an admin. Add yours to view the admin console + waitlist locally.
ADMIN_EMAILS="tech@discopenguin.com"

# Mollie payments — the optional tip on add-to-cart (docs/PRD-tip.md). Use a
# test_ key in dev, a live_ key in prod (wrangler secret). Profile is informational.
MOLLIE_API_KEY="<mollie test_ or live_ key>"
MOLLIE_PROFILE_ID="<pfl_ profile id>"
# Public base URL, used to build Mollie redirect + webhook URLs.
APP_URL="http://localhost:3000"

# VAPI in-app voice (issue #17). The X-Vapi-Secret you set on the assistant's
# server webhook; the /api/vapi/tool route verifies inbound calls against it.
VAPI_SERVER_SECRET="<x-vapi-secret you set on the assistant>"
# Signs the short-lived session tokens that bind a voice call to a household.
# Generate with: openssl rand -base64 32. Server-only, never shipped to browser.
VAPI_TOOL_TOKEN_SECRET="<openssl rand -base64 32>"
# Browser-safe (VITE_ prefix = the only vars allowed in the client bundle). The
# VAPI PUBLIC key starts in-app voice calls; it cannot call the REST API.
VITE_VAPI_PUBLIC_KEY="<vapi public key>"
# Browser-safe (VITE_ prefix). The provisioned assistant id.
VITE_VAPI_ASSISTANT_ID="<vapi assistant id>"
