# Local dev secrets for Smart Cart. Copy to .dev.vars (gitignored).
# Production values are wrangler secrets, never committed.

# D1 is a wrangler binding (no connection string needed locally).

# Better Auth: generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<openssl rand -base64 32>"
BETTER_AUTH_URL="http://localhost:3000"

# Resend transactional email (sign-in OTP code). Send from a verified domain.
RESEND_API_KEY="<resend api key>"

# LLM provider key for the meal-planning agent (at least one).
ANTHROPIC_API_KEY="<anthropic api key>"

# Gated access: comma-separated emails allowed to complete sign-in. The admin
# (tech@discopenguin.com) is always approved. Everyone else is waitlisted.
APPROVED_EMAILS="friend@example.com, tester@example.com"

# VAPI in-app voice (issue #17). The X-Vapi-Secret you set on the assistant's
# server webhook; the /api/vapi/tool route verifies inbound calls against it.
VAPI_SERVER_SECRET="<x-vapi-secret you set on the assistant>"
# Signs the short-lived session tokens that bind a voice call to a household.
# Generate with: openssl rand -base64 32. Server-only, never shipped to browser.
VAPI_TOOL_TOKEN_SECRET="<openssl rand -base64 32>"
# Browser-safe (VITE_ prefix = the only vars allowed in the client bundle). The
# VAPI PUBLIC key starts in-app voice calls; it cannot call the REST API.
VITE_VAPI_PUBLIC_KEY="<vapi public key>"
# Browser-safe (VITE_ prefix). The provisioned assistant id.
VITE_VAPI_ASSISTANT_ID="<vapi assistant id>"
