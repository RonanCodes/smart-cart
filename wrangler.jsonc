{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "smart-cart",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "workers_dev": true,
  "observability": {
    "enabled": true,
  },
  "vars": {
    "BETTER_AUTH_URL": "https://smartcart.ronanconnolly.dev",
  },
  "routes": [
    { "pattern": "smartcart.ronanconnolly.dev", "custom_domain": true },
  ],
}
